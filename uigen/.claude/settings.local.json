{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|ReadFile|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "node ./hooks/read_hook.js",
            "timeout": 300
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "jq . > pre-log.json"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "jq . > post-log.json"
          }
        ]
      }
    ]
  }
}